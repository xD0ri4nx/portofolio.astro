---

<Layout title="Dorian Ruieneanu | Character Sheet">
  <div class="min-h-screen bg-[#0a0a0a] text-[#ffb000] font-mono selection:bg-[#ffb000] selection:text-black p-4 md:p-8">
    
    <main class="max-w-5xl mx-auto border-2 border-[#ffb000] p-6 md:p-10 relative">
      
      <div class="pointer-events-none fixed inset-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,118,0.06))] z-50 bg-size-[100%_2px,3px_100%]"></div>

      <header class="grid grid-cols-1 md:grid-cols-4 gap-6 border-b-2 border-[#ffb000] pb-8 mb-8">
        <div class="md:col-span-3">
          <p class="text-xs uppercase tracking-widest opacity-70 mb-2">// PERSONNEL_FILE_0294</p>
          <h1 class="text-4xl md:text-6xl font-black uppercase mb-4 tracking-tighter">
            Dorian Ruieneanu
          </h1>
          <p class="max-w-xl text-sm leading-relaxed border-l-4 border-[#ffb000] pl-4 italic opacity-90">
            I am passionate about technology and especially programming. I like to learn and discover new things and to develop my skillset as a software engineer.
          </p>
        </div>
        <div class="border-2 border-[#ffb000] p-2 flex flex-col items-center justify-center bg-[#ffb000]/10 text-center">
          <p class="text-[10px] uppercase mb-1 tracking-widest">Status</p>
          <p class="text-xl font-bold animate-pulse uppercase">Active</p>
          <div class="w-full h-1 bg-[#ffb000] mt-4"></div>
          <p class="text-[8px] mt-2">CRAIOVA_ENGINEERING_DISTRICT</p>
        </div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-12">
        <section class="md:col-span-1">
          <h2 class="bg-[#ffb000] text-black px-2 py-1 text-sm font-bold uppercase mb-4">Core Attributes</h2>
          <div class="space-y-4">
            {stats.map(stat => (
              <div>
                <div class="flex justify-between text-xs mb-1">
                  <span>{stat.label} <span class="opacity-50 text-[10px]">({stat.desc.split('/')[0].trim()})</span></span>
                  <span>{stat.value * 10}%</span>
                </div>
                <div class="h-2 bg-[#ffb000]/20 w-full overflow-hidden">
                  <div class="h-full bg-[#ffb000]" style={`width: ${stat.value * 10}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section class="md:col-span-2">
          <h2 class="bg-[#ffb000] text-black px-2 py-1 text-sm font-bold uppercase mb-4">Technical Arsenal</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
            {skills.map(skill => (
              <div class="border border-[#ffb000]/40 p-2 text-[10px] hover:bg-[#ffb000] hover:text-black transition-colors cursor-crosshair">
                [X] {skill}
              </div>
            ))}
            <div class="border border-[#ffb000]/40 p-2 text-[10px] hover:bg-[#ffb000] hover:text-black transition-colors cursor-crosshair">
              [X] English (B2)
            </div>
            <div class="border border-[#ffb000]/40 p-2 text-[10px] hover:bg-[#ffb000] hover:text-black transition-colors cursor-crosshair">
              [X] French (B1)
            </div>
          </div>
        </section>
      </div>

      <section class="mb-12">
        <h2 class="bg-[#ffb000] text-black px-2 py-1 text-sm font-bold uppercase mb-6 italic underline">Combat Merits // Street Cred</h2>
        <div class="space-y-6">
          {diplomas.map(d => (
            <div class="flex items-start gap-4 group">
              <span class="text-[#ffb000] animate-pulse">>></span>
              <div>
                <h3 class="text-xl font-bold uppercase group-hover:bg-[#ffb000] group-hover:text-black transition-colors px-1 inline-block">
                  {d.title}
                </h3>
                <p class="text-sm opacity-80 mt-1">[{d.type}] // {d.date}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="bg-[#ffb000] text-black px-2 py-1 text-sm font-bold uppercase mb-6 italic underline">Active Missions // Featured Projects</h2>
        <div class="space-y-8">
          {projects.map(p => (
            <div class="flex items-start gap-4 group">
              <span class="text-[#ffb000] animate-pulse">>></span>
              <div>
                <h3 class="text-xl font-bold uppercase group-hover:bg-[#ffb000] group-hover:text-black transition-colors px-1 inline-block">
                  {p.title}
                </h3>
                <p class="text-sm opacity-80 mt-2 max-w-2xl">{p.description}</p>
                <div class="flex flex-wrap gap-2 mt-3">
                  {p.tech.map(t => (
                    <span class="text-[10px] border border-[#ffb000]/30 px-2 py-0.5">{t}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="bg-[#ffb000] text-black px-2 py-1 text-sm font-bold uppercase mb-6 italic underline">Academic Datastreams</h2>
        <div class="space-y-6">
          {education.map(e => (
            <div class="flex items-start gap-4 group">
              <span class="text-[#ffb000] animate-pulse">>></span>
              <div>
                <h3 class="text-xl font-bold uppercase group-hover:bg-[#ffb000] group-hover:text-black transition-colors px-1 inline-block">
                  {e.institution}
                </h3>
                <p class="text-sm opacity-80 mt-1">{e.degree} // <span class="font-bold">{e.period}</span></p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <footer class="border-t-2 border-[#ffb000] pt-8 flex flex-wrap gap-6 justify-center">
        <a href="https://github.com/xD0ri4nx" target="_blank" class="border-2 border-[#ffb000] px-6 py-2 text-xs font-bold hover:bg-[#ffb000] hover:text-black transition-all text-center">
          ESTABLISH_UPLINK (GITHUB)
        </a>
        <button data-copy={email} class="copy-btn border-2 border-[#ffb000] px-6 py-2 text-xs font-bold hover:bg-[#ffb000] hover:text-black transition-all">
          <span class="btn-text">TRANSMIT_DATA (EMAIL)</span>
        </button>
        <button data-copy={phone} class="copy-btn border-2 border-[#ffb000] px-6 py-2 text-xs font-bold hover:bg-[#ffb000] hover:text-black transition-all">
          <span class="btn-text">ESTABLISH_COMMS (PHONE)</span>
        </button>
      </footer>

    </main>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButtons = document.querySelectorAll('.copy-btn');
    copyButtons.forEach(button => {
      button.addEventListener('click', async () => {
        const textToCopy = button.getAttribute('data-copy');
        const textSpan = button.querySelector('.btn-text');
        if (!textToCopy || !textSpan) return;
        
        const originalText = textSpan.textContent || '';
        try {
          await navigator.clipboard.writeText(textToCopy);
          textSpan.textContent = 'PACKET_RECEIVED!';
          button.classList.add('bg-[#ffb000]', 'text-black');
          setTimeout(() => {
            textSpan.textContent = originalText;
            button.classList.remove('bg-[#ffb000]', 'text-black');
          }, 2000);
        } catch (err) {
          textSpan.textContent = 'UPLINK_FAILURE';
        }
      });
    });
  });
</script>

<style>
  @keyframes flicker {
    0% { opacity: 0.99; }
    5% { opacity: 0.95; }
    10% { opacity: 0.99; }
    100% { opacity: 1; }
  }
  main {
    animation: flicker 0.2s infinite;
  }
</style>