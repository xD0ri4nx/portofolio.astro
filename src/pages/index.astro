---
import Layout from '../layouts/Layout.astro';

// 🔍 SANITY CHECK: Update these two variables with your real contact info!
const email = "dorian.ruieneanu@example.com";
const phone = "+40 123 456 789";

const projects = [
  {
    title: "Fitness Tracker",
    description: "A management platform for clients to track workouts and nutrition, and for staff to manage database entries.",
    tech: ["C#", ".NET 9.0", "SQL"],
    github: "https://github.com/xD0ri4nx"
  },
  {
    title: "RSA Decryption Engine",
    description: "Performance simulator for RSA decryption scenarios utilizing sequential, system threads, and CUDA threads.",
    tech: ["C", "CUDA", "Multithreading"],
    github: "https://github.com/xD0ri4nx"
  },
  {
    title: "ACAT",
    description: "The ACE Computational Automata Tool. A visual representation tool for the abstract logic behind Automata and Formal Languages.",
    tech: ["TypeScript", "OOP"],
    github: "https://github.com/xD0ri4nx"
  },
  {
    title: "Bridging the Gap",
    description: "An AI-enabled versatile skill matching tool built during the 48-hour Craiova Hackathon challenge.",
    tech: ["AI", "Team Bugged"],
    github: "https://github.com/xD0ri4nx"
  }
];

const education = [
  {
    institution: "University of Craiova",
    degree: "Bachelor's Degree in Computer Engineering",
    period: "2022 - 2026"
  },
  {
    institution: "Carol I National College, Craiova",
    degree: "High School Diploma in Mathematics and Computer Science",
    period: "2018 - 2022"
  }
];

const skills = [
  'C', 'C++', 'C#', 'Java', 'TypeScript', 'HTML/CSS', 'SQL',
  '.NET', 'CUDA', 'AWS', 'EC2', 'GNU/Linux', 'VBox', 
  'OOP', 'Multithreading', 'Concurrency', 'Distributed Systems', 'AI'
];
---

<Layout title="Dorian Ruieneanu | Software Engineer"> 
  <div class="min-h-screen bg-slate-950 bg-[radial-gradient(ellipse_at_top,var(--tw-gradient-stops))] from-purple-900 via-slate-950 to-black text-fuchsia-50 selection:bg-pink-500 selection:text-white pb-20">
    <main class="max-w-6xl mx-auto px-6 py-16 md:py-24">
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        <section class="md:col-span-2 bg-purple-950/40 border border-pink-500/30 backdrop-blur-sm rounded-3xl p-8 md:p-12 flex flex-col justify-center shadow-[0_0_30px_rgba(217,70,239,0.1)]">
          <h1 class="text-5xl md:text-7xl font-black leading-tight mb-6 text-transparent bg-clip-text bg-linear-to-r from-pink-400 via-fuchsia-500 to-purple-500 drop-shadow-[0_0_15px_rgba(236,72,153,0.5)]">
            Dorian Ruieneanu 
          </h1>
          <p class="text-lg text-purple-200 max-w-xl mb-8 leading-relaxed font-medium">
            I am passionate about technology and especially programming. I like to learn and discover new things and to develop my skillset as a software engineer. 
          </p>
          
          <div class="flex flex-wrap gap-8 justify-center">
            <a href="https://github.com/xD0ri4nx" target="_blank" class="bg-linear-to-r from-pink-600 to-purple-700 text-white px-8 py-4 rounded-full font-bold uppercase tracking-widest hover:shadow-[0_0_20px_rgba(236,72,153,0.8)] hover:scale-105 transition-all duration-300 text-center"> 
              GitHub
            </a>
            
            <button data-copy={email} class="copy-btn bg-linear-to-r from-pink-600 to-purple-700 text-white px-8 py-4 rounded-full font-bold uppercase tracking-widest hover:shadow-[0_0_20px_rgba(236,72,153,0.8)] hover:scale-105 transition-all duration-300 flex items-center justify-center min-w-35">
              <span class="btn-text">Email</span>
            </button>
            
            <button data-copy={phone} class="copy-btn bg-linear-to-r from-pink-600 to-purple-700 text-white px-8 py-4 rounded-full font-bold uppercase tracking-widest hover:shadow-[0_0_20px_rgba(236,72,153,0.8)] hover:scale-105 transition-all duration-300 flex items-center justify-center min-w-35">
              <span class="btn-text">Phone</span>
            </button>
          </div>
        </section>

        <section class="bg-black/40 border border-purple-500/30 rounded-3xl p-8 text-white flex flex-col justify-between backdrop-blur-sm shadow-[inset_0_0_20px_rgba(168,85,247,0.15)]">
          <div class="space-y-6">
            <h2 class="text-2xl font-bold text-transparent bg-clip-text bg-linear-to-r from-purple-400 to-pink-400 uppercase tracking-widest">Technical Arsenal</h2>
            <div class="flex flex-wrap gap-2">
              {skills.map((skill) => (
                <span class="px-3 py-1 bg-purple-900/50 border border-purple-500/50 rounded-lg text-sm text-pink-200 shadow-[0_0_10px_rgba(168,85,247,0.2)]">
                  {skill}
                </span>
              ))}
            </div>
          </div>
          <div class="mt-12 pt-8 border-t border-purple-500/30">
            <p class="text-purple-400 text-sm mb-4 italic">Computer Engineering Student based in Craiova, Romania.</p> 
          </div>
        </section>
      </div>

      <section class="mt-20">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-black text-transparent bg-clip-text bg-linear-to-r from-pink-400 to-purple-500 uppercase tracking-widest drop-shadow-[0_0_10px_rgba(236,72,153,0.3)]">Education</h2>
        </div>
        
        <div class="space-y-4">
          {education.map((item) => (
            <div class="flex flex-col md:flex-row md:items-center justify-between p-6 bg-purple-950/20 border border-purple-500/20 rounded-2xl hover:border-pink-500/60 hover:bg-purple-900/40 transition-all duration-300 group shadow-[0_0_15px_rgba(0,0,0,0.5)]">
              <div>
                <h3 class="text-xl font-bold text-fuchsia-50 group-hover:text-pink-300 transition-colors">{item.institution}</h3>
                <p class="text-purple-300 font-medium mt-1">{item.degree}</p>
              </div>
              <div class="mt-4 md:mt-0">
                <span class="px-4 py-2 bg-black/50 border border-pink-500/40 rounded-full text-sm font-bold text-pink-400 whitespace-nowrap shadow-[0_0_10px_rgba(236,72,153,0.2)]">
                  {item.period}
                </span>
              </div>
            </div>
          ))}
        </div>
      </section>
      
      <section class="mt-24">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-black text-transparent bg-clip-text bg-linear-to-r from-pink-400 to-purple-500 uppercase tracking-widest drop-shadow-[0_0_10px_rgba(236,72,153,0.3)]">Featured Projects</h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {projects.map((project) => (
            <div class="group p-8 bg-black/40 border border-purple-500/30 rounded-3xl hover:border-pink-500 hover:shadow-[0_0_30px_rgba(236,72,153,0.3)] transition-all duration-500 flex flex-col justify-between backdrop-blur-md relative overflow-hidden">
              <div class="absolute top-0 left-0 w-full h-1 bg-linear-to-r from-transparent via-pink-500 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

              <div>
                <h3 class="text-2xl font-bold text-fuchsia-50 mb-3 group-hover:text-pink-400 group-hover:drop-shadow-[0_0_8px_rgba(236,72,153,0.8)] transition-all">{project.title}</h3>
                <p class="text-purple-200 mb-6 leading-relaxed">{project.description}</p>
              </div>
              
              <div>
                <div class="flex flex-wrap gap-2 mb-6">
                  {project.tech.map(tag => (
                    <span class="text-xs font-bold bg-purple-900/60 border border-purple-400/30 text-pink-300 px-3 py-1.5 rounded-full">{tag}</span>
                  ))}
                </div>
                <a href={project.github} target="_blank" class="inline-flex items-center font-bold text-pink-500 hover:text-pink-400 transition-colors uppercase tracking-wider text-sm">
                  View Source Code 
                  <svg class="w-4 h-4 ml-2 group-hover:translate-x-2 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </section>

    </main>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButtons = document.querySelectorAll('.copy-btn');
    
    copyButtons.forEach(button => {
      button.addEventListener('click', async () => {
        const textToCopy = button.getAttribute('data-copy');
        const textSpan = button.querySelector('.btn-text');
        
        // 🛠️ TypeScript Fix: Ensure the elements and data actually exist before running logic
        if (!textToCopy || !textSpan) return;
        
        // Use an empty string fallback to satisfy TypeScript's strict null checks
        const originalText = textSpan.textContent || '';
        
        try {
          await navigator.clipboard.writeText(textToCopy);
          
          textSpan.textContent = 'COPIED!';
          button.classList.add('brightness-125'); 
          
          setTimeout(() => {
            textSpan.textContent = originalText;
            button.classList.remove('brightness-125');
          }, 2000);
          
        } catch (err) {
          console.error('Failed to copy text: ', err);
          textSpan.textContent = 'ERROR';
          setTimeout(() => textSpan.textContent = originalText, 2000);
        }
      });
    });
  });
</script>