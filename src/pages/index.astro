---
import Layout from '../layouts/Layout.astro';

// 🔍 SANITY CHECK: Core Data
const email = "dorian.ruieneanu@example.com";
const phone = "+40 123 456 789";

const stats = [
  { label: "PYTH", value: 10, desc: "Python / ML / AI" },
  { label: "JAVA", value: 9, desc: "Spring Boot / OOP" },
  { label: "LNX", value: 9, desc: "Kernel / Bash / Sys" },
  { label: "ML", value: 8, desc: "Neural Networks" },
  { label: "SPRG", value: 8, desc: "Backend / Microserv" },
  { label: "SQL", value: 8, desc: "Database Arch" },
  { label: "CUDA", value: 9, desc: "GPGPU / Parallel" },
  { label: "C#", value: 8, desc: ".NET 9.0 Core" },
  { label: "OOP", value: 10, desc: "Architectural Logic" },
];

const skills = [
  "C++", "TypeScript", "HTML/CSS", "GNU/Linux", 
  "Distributed Systems", "Concurrency", "Multithreading", 
  "Virtual Machines (VBox)", "EC2 / AWS", "Artificial Intelligence", 
  "Formal Languages", "Automata Theory", "RSA Cryptography",
  "Engineering Principles", "Software Development Life Cycle"
];

const projects = [
  {
    title: "Fitness Tracker",
    description: "A management platform for clients to track workouts and nutrition, and for staff to manage database entries.",
    tech: ["C#", ".NET 9.0", "SQL"],
    github: "https://github.com/xD0ri4nx"
  },
  {
    title: "RSA Decryption Engine",
    description: "Performance simulator for RSA decryption scenarios utilizing sequential, system threads, and CUDA threads.",
    tech: ["C", "CUDA", "Multithreading"],
    github: "https://github.com/xD0ri4nx"
  },
  {
    title: "ACAT",
    description: "The ACE Computational Automata Tool. A visual representation tool for the abstract logic behind Automata and Formal Languages.",
    tech: ["TypeScript", "OOP"],
    github: "https://github.com/xD0ri4nx"
  },
  {
    title: "Bridging the Gap",
    description: "An AI-enabled versatile skill matching tool built during the 48-hour Craiova Hackathon challenge.",
    tech: ["AI", "Team Bugged"],
    github: "https://github.com/xD0ri4nx"
  }
];

const diplomas = [
  {
    title: "AI Agents Intensive (Google)",
    type: "Neural_Upgrade",
    date: "DEC_2025"
  },
  {
    title: "Craiova Hackathon: Team Bugged",
    type: "Field_Operation",
    date: "2025_CYCLE"
  },
  {
    title: "Bridging The Gap (EU Comm)",
    type: "System_Integrate",
    date: "DEC_2023"
  }
];

const education = [
  {
    institution: "University of Craiova",
    degree: "Bachelor's Degree in Computer Engineering",
    period: "2022 - 2026"
  },
  {
    institution: "Carol I National College, Craiova",
    degree: "High School Diploma in Mathematics and Computer Science",
    period: "2018 - 2022"
  }
